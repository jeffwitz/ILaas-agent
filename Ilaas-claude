#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LITELLM_CONFIG="${LITELLM_CONFIG:-$HOME/.config/litellm/ilaas-mistral.yaml}"
LITELLM_BIN="${LITELLM_BIN:-$HOME/.venvs/litellm/bin/litellm}"
LITELLM_HOST="${LITELLM_HOST:-127.0.0.1}"
LITELLM_PORT="${LITELLM_PORT:-4000}"
CLAUDE_ILAAS_HOST="${CLAUDE_ILAAS_HOST:-127.0.0.1}"
CLAUDE_ILAAS_PORT="${CLAUDE_ILAAS_PORT:-4002}"
ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-sk-local-dummy}"
LOG_DIR="${ILAAS_CLAUDE_LOG_DIR:-$HOME/.cache/Ilaas-claude}"
MODEL_CATALOG="${ILAAS_MODEL_CATALOG:-$HOME/.codex-ilaas/model-catalogs/ilaas-mistral.json}"
MODEL_PREFIX="claude-ilaas-"
DEFAULT_MODEL="claude-ilaas-ilaas-default"

started_pids=()

usage() {
  cat <<'EOF'
Usage: Ilaas-claude [claude args...]
       Ilaas-claude --list-models

Starts LiteLLM on :4000 if needed, starts an Anthropic Messages proxy on :4002
if needed, then runs Claude Code against ILaaS models.

Examples:
  Ilaas-claude
  Ilaas-claude --list-models
  Ilaas-claude -p --model qwen-3.6-35b-instruct "Réponds exactement: OK"
  Ilaas-claude -p --model claude-ilaas-qwen-3.6-35b-instruct "Réponds exactement: OK"

Environment overrides:
  LITELLM_CONFIG, LITELLM_BIN, LITELLM_HOST, LITELLM_PORT
  CLAUDE_ILAAS_HOST, CLAUDE_ILAAS_PORT, ANTHROPIC_API_KEY
  ILAAS_CLAUDE_LOG_DIR, ILAAS_CLAUDE_KEEP_SERVERS=1, ILAAS_MODEL_CATALOG
EOF
}

list_models() {
  if [[ ! -f "$MODEL_CATALOG" ]]; then
    echo "Ilaas-claude: model catalog not found: $MODEL_CATALOG" >&2
    echo "Run ./refresh_ilaas_models.py first." >&2
    exit 1
  fi
  python3 - "$MODEL_CATALOG" <<'PY'
import json
import sys
from pathlib import Path

catalog = json.loads(Path(sys.argv[1]).read_text())
for model in catalog.get("models", []):
    slug = model.get("slug")
    if not slug:
        continue
    note = ""
    if slug.startswith("llama-3.1-") or slug.startswith("llama-3.3-"):
        note = "  # chat only currently; Claude Code tools fail via LiteLLM/ILaaS"
    print(f"{slug}{note}")
PY
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ "${1:-}" == "--list-models" ]]; then
  list_models
  exit 0
fi

port_open() {
  local host="$1"
  local port="$2"
  timeout 1 bash -c ":</dev/tcp/${host}/${port}" >/dev/null 2>&1
}

wait_for_port() {
  local name="$1"
  local host="$2"
  local port="$3"
  local attempt
  for attempt in {1..80}; do
    if port_open "$host" "$port"; then
      return 0
    fi
    sleep 0.25
  done
  echo "Ilaas-claude: timed out waiting for ${name} on ${host}:${port}" >&2
  return 1
}

start_litellm() {
  if port_open "$LITELLM_HOST" "$LITELLM_PORT"; then
    echo "Ilaas-claude: LiteLLM already listening on ${LITELLM_HOST}:${LITELLM_PORT}" >&2
    return
  fi
  if [[ ! -x "$LITELLM_BIN" ]]; then
    if command -v litellm >/dev/null 2>&1; then
      LITELLM_BIN="$(command -v litellm)"
    else
      echo "Ilaas-claude: litellm not found. Set LITELLM_BIN or install LiteLLM." >&2
      exit 1
    fi
  fi
  if [[ ! -f "$LITELLM_CONFIG" ]]; then
    echo "Ilaas-claude: LiteLLM config not found: $LITELLM_CONFIG" >&2
    exit 1
  fi
  mkdir -p "$LOG_DIR"
  echo "Ilaas-claude: starting LiteLLM on ${LITELLM_HOST}:${LITELLM_PORT}" >&2
  "$LITELLM_BIN" --config "$LITELLM_CONFIG" --host "$LITELLM_HOST" --port "$LITELLM_PORT" >"$LOG_DIR/litellm.log" 2>&1 &
  started_pids+=("$!")
  wait_for_port "LiteLLM" "$LITELLM_HOST" "$LITELLM_PORT"
}

start_messages_proxy() {
  if port_open "$CLAUDE_ILAAS_HOST" "$CLAUDE_ILAAS_PORT"; then
    echo "Ilaas-claude: Messages proxy already listening on ${CLAUDE_ILAAS_HOST}:${CLAUDE_ILAAS_PORT}" >&2
    return
  fi
  mkdir -p "$LOG_DIR"
  echo "Ilaas-claude: starting Messages proxy on ${CLAUDE_ILAAS_HOST}:${CLAUDE_ILAAS_PORT}" >&2
  python3 "$ROOT_DIR/claude_ilaas_messages_proxy.py" \
    --host "$CLAUDE_ILAAS_HOST" \
    --port "$CLAUDE_ILAAS_PORT" \
    --upstream "http://${LITELLM_HOST}:${LITELLM_PORT}/v1" \
    >"$LOG_DIR/messages-proxy.log" 2>&1 &
  started_pids+=("$!")
  wait_for_port "Messages proxy" "$CLAUDE_ILAAS_HOST" "$CLAUDE_ILAAS_PORT"
}

cleanup() {
  if [[ "${ILAAS_CLAUDE_KEEP_SERVERS:-0}" == "1" ]]; then
    return
  fi
  local pid
  for pid in "${started_pids[@]}"; do
    if kill -0 "$pid" >/dev/null 2>&1; then
      kill "$pid" >/dev/null 2>&1 || true
    fi
  done
}

rewrite_model_args() {
  REWRITTEN_ARGS=()
  SELECTED_ILAAS_MODEL=""
  local rewrite_next=0
  local arg model
  for arg in "$@"; do
    if [[ "$rewrite_next" == "1" ]]; then
      model="$arg"
      if [[ "$model" != claude-* && "$model" != anthropic* && "$model" != opus && "$model" != sonnet && "$model" != haiku && "$model" != fable ]]; then
        model="${MODEL_PREFIX}${model}"
      fi
      SELECTED_ILAAS_MODEL="$model"
      REWRITTEN_ARGS+=("$model")
      rewrite_next=0
      continue
    fi
    case "$arg" in
      --model)
        REWRITTEN_ARGS+=("$arg")
        rewrite_next=1
        ;;
      --model=*)
        model="${arg#--model=}"
        if [[ "$model" != claude-* && "$model" != anthropic* && "$model" != opus && "$model" != sonnet && "$model" != haiku && "$model" != fable ]]; then
          model="${MODEL_PREFIX}${model}"
        fi
        SELECTED_ILAAS_MODEL="$model"
        REWRITTEN_ARGS+=("--model=${model}")
        ;;
      *)
        REWRITTEN_ARGS+=("$arg")
        ;;
    esac
  done
}

trap cleanup EXIT INT TERM

start_litellm
start_messages_proxy

export ANTHROPIC_BASE_URL="http://${CLAUDE_ILAAS_HOST}:${CLAUDE_ILAAS_PORT}"
export ANTHROPIC_API_KEY
export CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY="${CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY:-1}"
export ANTHROPIC_DEFAULT_OPUS_MODEL="${ANTHROPIC_DEFAULT_OPUS_MODEL:-$DEFAULT_MODEL}"
export ANTHROPIC_DEFAULT_SONNET_MODEL="${ANTHROPIC_DEFAULT_SONNET_MODEL:-$DEFAULT_MODEL}"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="${ANTHROPIC_DEFAULT_HAIKU_MODEL:-$DEFAULT_MODEL}"
export ANTHROPIC_DEFAULT_FABLE_MODEL="${ANTHROPIC_DEFAULT_FABLE_MODEL:-$DEFAULT_MODEL}"
export MAX_THINKING_TOKENS="${MAX_THINKING_TOKENS:-0}"

rewrite_model_args "$@"

CUSTOM_OPTION="${SELECTED_ILAAS_MODEL:-$DEFAULT_MODEL}"
case "$CUSTOM_OPTION" in
  *llama-3.1-8b*|*llama-3.3-70b*)
    echo "Ilaas-claude: warning: ${CUSTOM_OPTION#${MODEL_PREFIX}} currently fails with Claude Code tools through LiteLLM/ILaaS; use Qwen/Gemma/Mistral for agentic code editing." >&2
    ;;
esac
export ANTHROPIC_CUSTOM_MODEL_OPTION="${ANTHROPIC_CUSTOM_MODEL_OPTION:-$CUSTOM_OPTION}"
export ANTHROPIC_CUSTOM_MODEL_OPTION_NAME="${ANTHROPIC_CUSTOM_MODEL_OPTION_NAME:-ILaaS ${CUSTOM_OPTION#${MODEL_PREFIX}}}"
export ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION="${ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION:-ILaaS model through local gateway}"

claude "${REWRITTEN_ARGS[@]}"
