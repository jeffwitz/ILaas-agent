#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LITELLM_CONFIG="${LITELLM_CONFIG:-$HOME/.config/litellm/ilaas-mistral.yaml}"
LITELLM_BIN="${LITELLM_BIN:-$HOME/.venvs/litellm/bin/litellm}"
LITELLM_HOST="${LITELLM_HOST:-127.0.0.1}"
LITELLM_PORT="${LITELLM_PORT:-4000}"
OPENAI_API_KEY="${OPENAI_API_KEY:-sk-local-dummy}"
LOG_DIR="${ILAAS_OPENCODE_LOG_DIR:-$HOME/.cache/Ilaas-opencode}"
MODEL_CATALOG="${ILAAS_MODEL_CATALOG:-$HOME/.codex-ilaas/model-catalogs/ilaas-mistral.json}"
DEFAULT_MODEL="${ILAAS_OPENCODE_MODEL:-ilaas-default}"
PROVIDER_ID="ilaas"

started_pids=()

usage() {
  cat <<'EOF'
Usage: Ilaas-opencode [opencode args...]
       Ilaas-opencode --list-models

Starts LiteLLM on :4000 if needed, injects an OpenCode provider named "ilaas",
then runs OpenCode against ILaaS models.

Examples:
  Ilaas-opencode
  Ilaas-opencode --list-models
  Ilaas-opencode run --model qwen-3.6-35b-instruct "Réponds exactement: OK"
  Ilaas-opencode run -m ilaas/qwen-3.6-35b-instruct "Réponds exactement: OK"

Environment overrides:
  LITELLM_CONFIG, LITELLM_BIN, LITELLM_HOST, LITELLM_PORT
  OPENAI_API_KEY, ILAAS_OPENCODE_LOG_DIR, ILAAS_OPENCODE_KEEP_SERVER=1
  ILAAS_MODEL_CATALOG, ILAAS_OPENCODE_MODEL
EOF
}

list_models() {
  if [[ ! -f "$MODEL_CATALOG" ]]; then
    echo "Ilaas-opencode: model catalog not found: $MODEL_CATALOG" >&2
    echo "Run ./refresh_ilaas_models.py first." >&2
    exit 1
  fi
  python3 - "$MODEL_CATALOG" <<'PY'
import json
import sys
from pathlib import Path

catalog = json.loads(Path(sys.argv[1]).read_text())
for model in catalog.get("models", []):
    slug = model.get("slug")
    if not slug:
        continue
    note = ""
    if slug.startswith("llama-3.1-") or slug.startswith("llama-3.3-"):
        note = "  # chat only / weak tool-calling candidate"
    print(f"{slug}{note}")
PY
}

port_open() {
  local host="$1"
  local port="$2"
  timeout 1 bash -c ":</dev/tcp/${host}/${port}" >/dev/null 2>&1
}

wait_for_port() {
  local name="$1"
  local host="$2"
  local port="$3"
  local attempt
  for attempt in {1..80}; do
    if port_open "$host" "$port"; then
      return 0
    fi
    sleep 0.25
  done
  echo "Ilaas-opencode: timed out waiting for ${name} on ${host}:${port}" >&2
  return 1
}

start_litellm() {
  if port_open "$LITELLM_HOST" "$LITELLM_PORT"; then
    echo "Ilaas-opencode: LiteLLM already listening on ${LITELLM_HOST}:${LITELLM_PORT}" >&2
    return
  fi
  if [[ ! -x "$LITELLM_BIN" ]]; then
    if command -v litellm >/dev/null 2>&1; then
      LITELLM_BIN="$(command -v litellm)"
    else
      echo "Ilaas-opencode: litellm not found. Set LITELLM_BIN or install LiteLLM." >&2
      exit 1
    fi
  fi
  if [[ ! -f "$LITELLM_CONFIG" ]]; then
    echo "Ilaas-opencode: LiteLLM config not found: $LITELLM_CONFIG" >&2
    exit 1
  fi
  mkdir -p "$LOG_DIR"
  echo "Ilaas-opencode: starting LiteLLM on ${LITELLM_HOST}:${LITELLM_PORT}" >&2
  "$LITELLM_BIN" --config "$LITELLM_CONFIG" --host "$LITELLM_HOST" --port "$LITELLM_PORT" >"$LOG_DIR/litellm.log" 2>&1 &
  started_pids+=("$!")
  wait_for_port "LiteLLM" "$LITELLM_HOST" "$LITELLM_PORT"
}

cleanup() {
  if [[ "${ILAAS_OPENCODE_KEEP_SERVER:-0}" == "1" ]]; then
    return
  fi
  local pid
  for pid in "${started_pids[@]}"; do
    if kill -0 "$pid" >/dev/null 2>&1; then
      kill "$pid" >/dev/null 2>&1 || true
    fi
  done
}

build_config_content() {
  if [[ ! -f "$MODEL_CATALOG" ]]; then
    echo "Ilaas-opencode: model catalog not found: $MODEL_CATALOG" >&2
    echo "Run ./refresh_ilaas_models.py first." >&2
    exit 1
  fi
  python3 - "$MODEL_CATALOG" "$PROVIDER_ID" "$DEFAULT_MODEL" "http://${LITELLM_HOST}:${LITELLM_PORT}/v1" <<'PY'
import json
import sys
from pathlib import Path

catalog_path, provider_id, default_model, base_url = sys.argv[1:]
catalog = json.loads(Path(catalog_path).read_text())
models = {}
for model in catalog.get("models", []):
    slug = model.get("slug")
    if not slug:
        continue
    models[slug] = {
        "name": model.get("display_name") or slug,
        "limit": {
            "context": int(model.get("context_window") or 262144),
            "output": 4096,
        },
    }

config = {
    "$schema": "https://opencode.ai/config.json",
    "model": f"{provider_id}/{default_model}",
    "small_model": f"{provider_id}/{default_model}",
    "provider": {
        provider_id: {
            "npm": "@ai-sdk/openai-compatible",
            "name": "ILaaS via LiteLLM",
            "options": {
                "baseURL": base_url,
                "apiKey": "{env:OPENAI_API_KEY}",
                "timeout": 600000,
                "chunkTimeout": 60000,
            },
            "models": models,
        }
    },
}
print(json.dumps(config, ensure_ascii=False, separators=(",", ":")))
PY
}

rewrite_model_args() {
  REWRITTEN_ARGS=()
  local rewrite_next=0
  local arg model
  for arg in "$@"; do
    if [[ "$rewrite_next" == "1" ]]; then
      model="$arg"
      if [[ "$model" != */* ]]; then
        model="${PROVIDER_ID}/${model}"
      fi
      REWRITTEN_ARGS+=("$model")
      rewrite_next=0
      continue
    fi
    case "$arg" in
      -m|--model)
        REWRITTEN_ARGS+=("$arg")
        rewrite_next=1
        ;;
      --model=*)
        model="${arg#--model=}"
        if [[ "$model" != */* ]]; then
          model="${PROVIDER_ID}/${model}"
        fi
        REWRITTEN_ARGS+=("--model=${model}")
        ;;
      *)
        REWRITTEN_ARGS+=("$arg")
        ;;
    esac
  done
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ "${1:-}" == "--list-models" ]]; then
  list_models
  exit 0
fi

trap cleanup EXIT INT TERM

start_litellm
export OPENAI_API_KEY
export OPENCODE_CONFIG_CONTENT
OPENCODE_CONFIG_CONTENT="$(build_config_content)"

rewrite_model_args "$@"
exec opencode "${REWRITTEN_ARGS[@]}"
